AUTOSTREAM_NODE_CONFIG=/etc/autostream-node/config.yml
# Optional override for local/dev builds. Release and Docker builds embed this automatically.
# SERVICE_VERSION=dev
CONTROL_PANEL_TIMEOUT_SEC=5
CONTROL_PANEL_HEARTBEAT_INTERVAL_SEC=30
# Panel-generated config.yml supplies SERVICE_ID, SERVICE_NAME,
# SERVICE_PUBLIC_URL, CONTROL_PANEL_URL, and CONTROL_PANEL_TOKEN.
# Standard operation receives Worker / Encoder Recorder signals through Control Panel
# using the admin token scope `observability.ingest`. Direct ingest token hashes are
# compatibility fallback only:
# OBSERVABILITY_INGEST_TOKEN_SHA256=<SHA256_OF_OBSERVABILITY_INGEST_TOKEN>
# OBSERVABILITY_INGEST_TOKEN_BINDINGS=<SHA256_OF_OBSERVABILITY_INGEST_TOKEN>:encoder_recorder:encoder-recorder-01,<SHA256_OF_OBSERVABILITY_INGEST_TOKEN>:worker:worker-01
# OBSERVABILITY_REQUIRE_INGEST_TOKEN_BINDINGS=true
OBSERVABILITY_ADMIN_TOKEN_SHA256=<SHA256_OF_CONTROL_PANEL_OBSERVABILITY_TOKEN>
# Format: <SHA256>:<scope>|<scope>,...
OBSERVABILITY_ADMIN_TOKEN_BINDINGS=<SHA256_OF_CONTROL_PANEL_OBSERVABILITY_TOKEN>:observability.read|observability.ingest|incidents.update|notifications.read|notifications.manage|remediation.read|remediation.approve|remediation.execute
OBSERVABILITY_REQUIRE_ADMIN_TOKEN_BINDINGS=true
# Notification channels are managed by Control Panel or the Observability API.
# Webhook URLs and SMTP passwords must not be placed in service env for normal production.
# Legacy single-webhook fallback is supported only for phased migration/local checks:
# NOTIFICATION_WEBHOOK_TYPE=generic
# NOTIFICATION_WEBHOOK_URL=https://example.com/webhook/<WEBHOOK_TOKEN>
NOTIFICATION_WEBHOOK_TIMEOUT_SEC=5
NOTIFICATION_WEBHOOK_RETRY_MAX=3
NOTIFICATION_WEBHOOK_RETRY_BASE_DELAY_SEC=1
OBSERVABILITY_ALLOW_PRIVATE_WEBHOOKS=false
OBSERVABILITY_ALLOW_PRIVATE_SMTP=false
OBSERVABILITY_RATE_LIMIT_BACKEND=store
OBSERVABILITY_TRUSTED_PROXIES=127.0.0.1
OBSERVABILITY_RATE_LIMIT_BURST=120
OBSERVABILITY_RATE_LIMIT_WINDOW_SEC=60
OBSERVABILITY_RATE_LIMIT_MAX_BUCKETS=10000
REMEDIATION_MODE=suggest_only
AUTOSTREAM_SECRET_ENCRYPTION_KEY=<32_BYTE_BASE64_OR_HEX_ENCRYPTION_KEY>
OBSERVABILITY_THRESHOLD_HEARTBEAT_AGE_SEC=30
OBSERVABILITY_THRESHOLD_DISK_FREE_BYTES=10737418240
OBSERVABILITY_THRESHOLD_REMUX_SLOW_MS=300000
OBSERVABILITY_THRESHOLD_GDRIVE_UPLOAD_RETRY_COUNT=3
OBSERVABILITY_THRESHOLD_PACKET_LOSS_PERCENT=5
OBSERVABILITY_THRESHOLD_RTMPS_RECONNECT_COUNT=3
OBSERVABILITY_THRESHOLD_ENCODER_LOW_FPS=45
OBSERVABILITY_THRESHOLD_ENCODER_LOW_BITRATE_KBPS=3000
OBSERVABILITY_THRESHOLD_ENCODER_DROPPED_FRAMES_TOTAL=30
OBSERVABILITY_THRESHOLD_AUDIO_SILENCE_SEC=5
OBSERVABILITY_THRESHOLD_AUDIO_CLIPPING_TOTAL=10
OBSERVABILITY_THRESHOLD_DISCORD_AUDIO_FORWARD_STALE_SEC=5
OBSERVABILITY_THRESHOLD_DISCORD_AUDIO_FORWARD_ERRORS_TOTAL=3
OBSERVABILITY_THRESHOLD_MEDIA_INPUT_TIMEOUT_SEC=5
OBSERVABILITY_THRESHOLD_STREAM_START_TIMEOUT_MS=120000
OBSERVABILITY_THRESHOLD_STREAM_STOP_TIMEOUT_MS=120000
AUTOSTREAM_BIND_ADDR=127.0.0.1:8080
DATABASE_URL=mysql://autostream:<PASSWORD>@tcp(mariadb:3306)/autostream_observability?parseTime=true
TZ=Asia/Tokyo
